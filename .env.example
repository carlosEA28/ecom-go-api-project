# Database Configuration
# Connection string para Goose e migrations
GOOSE_DBSTRING=host=localhost port=5432 user=postgres password=postgres dbname=ecom sslmode=disable

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# RDS Configuration (After Pulumi deployment)
RDS_ENDPOINT=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=ecom
RDS_USERNAME=postgres
RDS_PASSWORD=your-secure-password

# Pulumi Configuration
PULUMI_STACK=dev
PULUMI_ACCESS_TOKEN=your-pulumi-access-token
PULUMI_CLOUD_URL=s3://your-bucket-name

# Application Configuration
APP_PORT=8080
APP_ENV=development

# Logging
LOG_LEVEL=info
